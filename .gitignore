# Obsidian 本地工作区（不同设备不同）
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 临时文件
*.tmp
*.bak

# JARVIS SQLite（本地状态，WAL sidecar文件）
.jarvis/data/jarvis.db
.jarvis/data/jarvis.db-wal
.jarvis/data/jarvis.db-shm

# JARVIS 日志（本地运行产生）
.jarvis/data/*.log
.jarvis/data/launchd-sync.*

# 投资区本地缓存（各设备独立）
个人投资专区/.etf_flows.json
个人投资专区/.mstr_holdings.json
个人投资专区/.structural_cache.json
个人投资专区/.price_cache.json
个人投资专区/.daily_brief_history.json
