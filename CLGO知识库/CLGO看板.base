headings:
  - key: title
    name: 课程
    type: text
  - key: domain
    name: 知识领域
    type: text
  - key: status
    name: 状态
    type: text
  - key: courses
    name: 原始课程
    type: list
  - key: tags
    name: 标签
    type: tags
filter:
  conjunction: and
  conditions:
    - field: tags
      operator: contains
      value: CLGO
group:
  field: domain
sort:
  - field: domain
    order: asc
  - field: title
    order: asc
sources:
  - CLGO知识库
views:
  - type: table
    name: 表格
